#include <iostream>
#include <string>
#include <vector>

struct Patient {
    std::string name;
    int severity; // 1 = mild, 5 = critical
};

class TriageSystem {
private:
    std::vector<Patient> patients;
public:
    void addPatient(const std::string& name, int severity) {
        patients.push_back({name, severity});
        std::cout << "Patient " << name << " added with severity " << severity << ".\n";
    }

    void listPatients() {
        std::cout << "\n--- ER You Ready? Patient List ---\n";
        for (const auto& p : patients) {
            std::cout << "Name: " << p.name 
                      << " | Severity: " << p.severity << "\n";
        }
    }

    void nextPatient() {
        if (patients.empty()) {
            std::cout << "No patients waiting. ER is calm... for now.\n";
            return;
        }
        // Find the most severe case
        int index = 0;
        for (int i = 1; i < patients.size(); ++i) {
            if (patients[i].severity > patients[index].severity) {
                index = i;
            }
        }
        std::cout << "Next patient: " << patients[index].name 
                  << " (Severity " << patients[index].severity << ")\n";
        patients.erase(patients.begin() + index);
    }
};

int main() {
    TriageSystem system;
    system.addPatient("Alice", 3);
    system.addPatient("Bob", 5);
    system.addPatient("Charlie", 2);

    system.listPatients();
    system.nextPatient();
    system.listPatients();

    return 0;
}
